rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user's data lives at users/{uid}. A signed-in user can read & write
    // ONLY their own document — nobody else's. This is the real protection;
    // the public apiKey cannot bypass it.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // The admin account may READ every user document (for admin.html).
      // Server-enforced via the verified token email — a client-side check alone
      // is not trusted. For stronger security, switch to a custom claim:
      //   allow read: if request.auth.token.admin == true;
      allow read: if request.auth != null
                  && request.auth.token.email == 'jacopodaffy@gmail.com';
    }

    // Collaborative lists by code. Any signed-in user (including anonymous
    // sign-in, used so no account is required) may read & write a shared list
    // whose code they know — security is the secrecy of the random code, like a
    // share link. Holds only list content (title/colour/items), never personal
    // data. Private lists stay locked at users/{uid} above.
    // Writes must match the exact shape the app sends (sharePayload in app.js):
    // server-side belt on top of the client-side sanitiser.
    match /shared/{code} {
      allow read, delete: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.keys().hasOnly(['code', 'title', 'color', 'items', 'updatedAt'])
        && request.resource.data.code == code
        && request.resource.data.title is string && request.resource.data.title.size() <= 80
        && request.resource.data.color is string && request.resource.data.color.size() <= 12
        && request.resource.data.items is list && request.resource.data.items.size() <= 500
        && request.resource.data.updatedAt is number;
    }

    // Global leaderboard — anyone signed in can read; each user writes only their
    // own entry, and only in the exact shape publishLeaderboard() sends
    // (name + numeric score fields — no email, no list content, no HTML-bearing
    // extra fields).
    match /leaderboard/{uid} {
      allow read: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == uid;
      allow create, update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['uid', 'name', 'points', 'completed', 'badges', 'updatedAt'])
        && request.resource.data.uid == uid
        && request.resource.data.name is string && request.resource.data.name.size() <= 40
        && request.resource.data.points is number
        && request.resource.data.completed is number
        && request.resource.data.badges is number
        && request.resource.data.updatedAt is number;
    }

    // User profiles (registration records).
    match /profiles/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
