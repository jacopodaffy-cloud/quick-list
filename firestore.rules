rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user's data lives at users/{uid}. A signed-in user can read & write
    // ONLY their own document — nobody else's. This is the real protection;
    // the public apiKey cannot bypass it.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // The admin account may READ every user document (for admin.html).
      // Server-enforced via the verified token email — a client-side check alone
      // is not trusted. For stronger security, switch to a custom claim:
      //   allow read: if request.auth.token.admin == true;
      allow read: if request.auth != null
                  && request.auth.token.email == 'jacopodaffy@gmail.com';
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
