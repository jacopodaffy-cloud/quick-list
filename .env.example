# QuickList is a static web app: the browser config (Firebase web keys) is PUBLIC
# by design and lives in config.js. There are NO frontend secrets to hide here.
#
# This file exists for the day you add a BACKEND (e.g. Firebase Cloud Functions).
# Real secrets go in environment variables on the server, never in the repo:
#   firebase functions:config:set someservice.key="THE_SECRET"
# or, for a Node backend, a gitignored .env (already in .gitignore):
#
# STRIPE_SECRET_KEY=
# SENDGRID_API_KEY=
# FIREBASE_ADMIN_PRIVATE_KEY=
#
# Copy to .env (gitignored) and fill in only on the server.
